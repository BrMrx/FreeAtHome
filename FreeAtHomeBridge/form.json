{
  "elements": [
    {
    "name": "Host",
    "type": "ValidationTextBox",
    "caption": "IP-Adress SysAP"
  },
  {
    "type": "ValidationTextBox",
    "name": "Username",
    "caption": "Username"
  },
  {
    "type": "PasswordTextBox",
    "name": "Password",
    "caption": "Password"
  },
  {
      "name": "UpdateInterval",
      "type": "IntervalBox",
      "caption": "Seconds"
  },
  {
      "type": "CheckBox",
      "name": "UseTLS",
      "caption": "Use TLS (https/wss)"
  },
  {
    "type": "ExpansionPanel",
    "caption": "WebSocket",
    "items": [
      {
        "type": "CheckBox",
        "name": "UseWebSocket",
        "caption": "Enable WebSocket push"
      },
      {
        "type": "NumberSpinner",
        "name": "WebSocketPort",
          "caption": "WebSocket port (0 = auto)",
          "minimum": 0,
          "maximum": 65535
      },
      {
        "type": "NumberSpinner",
        "name": "WsKeepaliveSec",
        "caption": "Keepalive ping interval (s)",
        "minimum": 5,
        "maximum": 600
      },
      {
        "type": "NumberSpinner",
        "name": "WsStaleTimeoutSec",
        "caption": "Stale timeout (s, 0 = off)",
        "minimum": 0,
        "maximum": 3600
      }
    ]
  },
  {
      "type": "ValidationTextBox",
      "enabled": false,
     "name": "SysAPName",
      "caption": "SysAP name"
    },
    {
      "type": "ValidationTextBox",
      "enabled": false,
      "name": "SysAPFirmware",
      "caption": "SysAP firmware"
    }, 
    {
      "type": "ValidationTextBox",
      "enabled": false,
      "name": "SysAP_GUID",
      "caption": "SysAP GUID"
    } 
   ],
  "actions": [
    { "type": "Button", "label": "Check Connection", "onClick": "FAHBR_CheckConnection($id);" },
    { "type": "Button", "label": "WebSocket: Connect", "onClick": "FAHBR_WsConnect($id);" },
    { "type": "Button", "label": "WebSocket: Disconnect", "onClick": "FAHBR_WsDisconnect($id);" },
    { "type": "Button", "label": "WebSocket: Send Ping", "onClick": "FAHBR_WsSendPing($id);" }
  ],
  "status": [
    {
      "code": 102,
      "icon": "active",
      "caption": "Registration complete"
    },
    {
      "code": 200,
      "icon": "error",
      "caption": "Registration incomplete, more Information in IP-Symcon Log"
    },
    {
      "code": 201,
      "icon": "error",
      "caption": "Invalid JSON"
    },
    {
      "code": 202,
      "icon": "error",
      "caption": "free@home Bridge unreachable"
    }
  ]  
}